# =============================================================================
# PM Radar Configuration
# Copy this file to .env and fill in your API keys
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI API (Required)
# Used for: Content analysis with GPT-4o
# Get your key: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-...

# -----------------------------------------------------------------------------
# Reddit API (Required)
# Used for: Community sentiment analysis from r/twilio
# Get your credentials: https://www.reddit.com/prefs/apps
# Create a "script" type application
# -----------------------------------------------------------------------------
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here

# -----------------------------------------------------------------------------
# Brevo/SendInBlue Email API (Required)
# Used for: Weekly email delivery
# Get your key: https://app.brevo.com/settings/keys/api
# -----------------------------------------------------------------------------
BREVO_API_KEY=xkeysib-...
BREVO_SENDER_EMAIL=your-email@example.com
BREVO_SENDER_NAME=PM Radar

# -----------------------------------------------------------------------------
# AWS (Optional - Future use)
# Required for: Claude-based AI agents (not currently used)
# Only needed if switching from OpenAI to AWS Bedrock
# -----------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
