# OpenAI (for analysis)
OPENAI_API_KEY=sk-proj-your-openai-key-here

# Anthropic (alternative LLM provider)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# SociaVault (for Reddit data - get from https://sociavault.com)
SOCIAVAULT_API_KEY=sk_live_your-sociavault-key-here

# Socialcrawl (for Twitter/Reddit data - get from https://socialcrawl.com)
SOCIALCRAWL_API_KEY=sc_your-socialcrawl-key-here

# Brevo Email (for email delivery - get from https://app.brevo.com/settings/keys/api)
BREVO_API_KEY=xkeysib-your-brevo-key-here

# Optional: Report recipients (comma-separated emails)
# REPORT_RECIPIENTS=team@example.com,manager@example.com
